        620
      ]
    },
    {
      "parameters": {
        "jsCode": "const rawHtml = $input.first().json.data || $input.first().json || '';\nconst validated = $('Validar URL').first().json;\nlet text = String(rawHtml)\n  .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, ' ')\n  .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, ' ')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<').replace(/&gt;/g, '>')\n  .replace(/&quot;/g, '\"')\n  .replace(/\\s{2,}/g, ' ').trim();\nif (text.length > 4000) text = text.slice(0, 4000) + '...';\nreturn [{ json: {\n  text,\n  source_url: validated.url,\n  ai_provider: validated.ai_provider,\n  ai_model: validated.ai_model\n} }];"
      },

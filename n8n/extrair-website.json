    {
      "parameters": {
        "jsCode": "const errData = $input.first().json;\nconst sourceData = $('Extrair Texto').first().json;\nconst provider = sourceData.ai_provider || 'openai';\nconst errMsg = errData.error?.message || errData.message || 'Erro ao chamar a IA';\nconst status = errData.error?.status || errData.statusCode || 0;\nlet userMsg = `Erro na IA (${provider}): ${errMsg}`;\nif (status === 401) userMsg = `Chave de API da ${provider} inválida ou não configurada no n8n.`;\nif (status === 402 || status === 529) userMsg = `Sem créditos na conta ${provider}. Adicione créditos no painel da ${provider}.`;\nif (status === 429) userMsg = 'Limite de requisições atingido. Aguarde alguns instantes.';\nreturn [{ json: { words: [], count: 0, error: userMsg, source_url: sourceData.source_url || '' } }];"
      },

    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/{{ $json.ai_model || 'gemini-1.5-flash' }}:generateContent",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpQueryAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\"parts\": [{\"text\": \"Analise este texto em inglês e identifique palavras, phrasal verbs e idioms de nível B2 ou acima que um estudante brasileiro intermediário provavelmente não conhece.\\n\\nRetorne SOMENTE um array JSON com até 20 itens, cada um com: word, context (a frase do texto onde aparece), type (word/phrasal_verb/idiom), level (B2/C1/C2).\\n\\nTexto:\\n{{ $json.text.replace(/\"/g, \"'\").replace(/[\\n\\r\\t]/g, ' ').replace(/\\\\+/g, ' ') }}\\n\\nResposta (APENAS o array JSON):\"}]}\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "site-ai-google",
      "name": "Google Gemini — Identificar Vocabulário",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,

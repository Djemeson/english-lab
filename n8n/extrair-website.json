      "parameters": {
        "jsCode": "const validated = $('Validar URL').first().json;\nconst err = $input.first().json;\nconst msg = err.message || err.cause?.message || 'Erro ao buscar a página';\nreturn [{ json: { words: [], count: 0, error: msg, source_url: validated.url } }];"
      },

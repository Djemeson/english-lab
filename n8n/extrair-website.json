    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst sourceData = $('Extrair Texto').first().json;\nconst provider = sourceData.ai_provider || 'openai';\n\nlet text = '';\nif (provider === 'openai') {\n  text = response.choices?.[0]?.message?.content || '[]';\n} else if (provider === 'anthropic') {\n  text = response.content?.[0]?.text || '[]';\n} else if (provider === 'google') {\n  text = response.candidates?.[0]?.content?.parts?.[0]?.text || '[]';\n}\n\nreturn [{ json: { raw_text: text, source_url: sourceData.source_url } }];"
      },
      "id": "site-0006",
      "name": "Normalizar — Resposta IA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const { raw_text, source_url } = $input.first().json;\n\nlet words = [];\ntry {\n  const match = raw_text.match(/\\[[\\s\\S]*\\]/);\n  if (match) words = JSON.parse(match[0]);\n} catch(e) { words = []; }\n\nwords = words.map(w => ({\n  ...w,\n  source_type: 'website',\n  source_title: source_url\n}));\n\nreturn [{ json: { words, count: words.length, source_url } }];"
      },
      "id": "site-0007",
      "name": "Parsear Vocabulário",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,

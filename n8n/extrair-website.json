    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst url = (body.url || '').trim();\nconst rawAI = (body.ai_provider || 'openai').toLowerCase();\nconst aiModel = (body.ai_model || '').trim();\nif (!url) throw new Error('URL não fornecida');\nif (!url.startsWith('http')) throw new Error('URL inválida: deve começar com http:// ou https://');\nconst validAI = ['openai', 'anthropic', 'google'];\nreturn [{ json: {\n  url,\n  ai_provider: validAI.includes(rawAI) ? rawAI : 'openai',\n  ai_model: aiModel\n} }];"
      },
      "id": "site-0002",
      "name": "Validar URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.url }}",
        "options": {
          "timeout": 20000,
          "response": {
            "response": {
              "responseFormat": "text"
            }
          },
          "redirect": {
            "redirect": {
              "followRedirects": true,
              "maxRedirects": 3

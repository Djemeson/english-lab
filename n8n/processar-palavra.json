        "jsCode": "const body = $input.first().json;\nconst word = (body.word || '').trim();\nconst context = (body.context || '').trim();\nconst sourceType = body.source_type || 'manual';\nconst sourceTitle = body.source_title || '';\nconst rawAI = (body.ai_provider || 'anthropic').toLowerCase();\nconst rawTTS = (body.tts_provider || 'openai').toLowerCase();\nif (!word && !context) throw new Error('Nenhuma palavra ou contexto fornecido');\nconst validAI = ['anthropic', 'openai', 'google'];\nconst validTTS = ['openai', 'elevenlabs', 'google', 'none'];\nreturn [{ json: {\n  word, context,\n  source_type: sourceType, source_title: sourceTitle,\n  ai_provider: validAI.includes(rawAI) ? rawAI : 'anthropic',\n  tts_provider: validTTS.includes(rawTTS) ? rawTTS : 'openai',\n  timestamp: new Date().toISOString()\n} }];"
      },

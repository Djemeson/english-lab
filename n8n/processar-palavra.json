    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst orig = $('Validar Input').first().json;\nlet ai = {};\ntry { const m = (input.raw_ai_text||'').match(/\\{[\\s\\S]*\\}/); if(m) ai=JSON.parse(m[0]); } catch(e){}\nreturn [{ json: {\n  word: ai.word||orig.word, type: ai.type||'word',\n  ipa: ai.ipa||'', meaning_pt: ai.meaning_pt||'',\n  examples: ai.examples||[], level: ai.level||'', tags: ai.tags||[],\n  context: orig.context, source_type: orig.source_type, source_title: orig.source_title,\n  ai_provider: orig.ai_provider, tts_provider: orig.tts_provider,\n  processed: true, processed_at: new Date().toISOString()\n} }];"

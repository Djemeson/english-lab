    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst provider = $('Validar Input').first().json.ai_provider || 'anthropic';\nlet rawText = '';\nif (provider === 'anthropic') rawText = response.content?.[0]?.text || '';\nelse if (provider === 'openai') rawText = response.choices?.[0]?.message?.content || '';\nelse if (provider === 'google') rawText = response.candidates?.[0]?.content?.parts?.[0]?.text || '';\nif (!rawText) throw new Error('Provider ' + provider + ' retornou resposta vazia.');\nreturn [{ json: { raw_ai_text: rawText } }];"
      },
      "id": "b0080000-0000-0000-0000-000000000008",
      "name": "Normalizar — Resposta IA",
